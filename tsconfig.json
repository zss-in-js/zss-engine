{
  "compilerOptions": {
    "rootDir": ".",
    "esModuleInterop": true,
    "lib": ["ESNext", "dom"],
    "types": ["jest", "node"],
    "module": "ES2022",
    "noImplicitReturns": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "strict": true,
    "target": "ES2022",
    "noEmitOnError": false,
    "skipLibCheck": true,
    "removeComments": true
  },
  "include": ["src", "tests"],
  "exclude": ["node_modules"]
}
